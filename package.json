{
  "name": "midori-newtab",
  "private": true,
  "version": "1.0.36",
  "type": "module",
  "scripts": {
    "dev:chrome": "npm run build:manifest:chrome && vite build --watch",
    "dev:firefox": "npm run build:manifest:firefox && vite build --watch",
    "build:manifest:chrome": "node build-manifest.js manifest/chrome.json",
    "build:manifest:firefox": "node build-manifest.js manifest/firefox.json",
    "build:chrome": "npm run build:manifest:chrome && vite build",
    "build:firefox": "npm run build:manifest:firefox && vite build",
    "analyze:bundle": "ANALYZE_BUNDLE=1 npm run build:chrome",
    "package:chrome": "npm run build:chrome && node scripts/package.js chrome",
    "package:firefox": "npm run build:firefox && node scripts/package.js firefox",
    "preview": "vite preview",
    "validate:contracts": "node contracts/scripts/validate-examples.mjs",
    "test:contracts": "node --test contracts/tests/*.test.mjs",
    "test:update": "node --test tests/**/*.test.mjs"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.4.1",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.3",
    "@types/firefox-webext-browser": "^120.0.4",
    "@vitejs/plugin-vue": "^6.0.0",
    "ajv": "^8.17.1",
    "terser": "^5.46.2",
    "typescript": "^5.9.2",
    "vite": "^7.0.4",
    "vite-plugin-static-copy": "^3.1.1",
    "vite-plugin-web-extension": "^4.4.5",
    "vue-tsc": "^3.0.5"
  }
}
