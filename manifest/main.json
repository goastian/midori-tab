{
  "manifest_version": 3,
  "name": "midori-tab",
  "description": "A beautiful, customizable new tab with smart search, workspaces and bookmarks.",
  "author": "Astian, Inc",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "identity",
    "tabs",
    "activeTab",
    "bookmarks",
    "history",
    "browsingData",
    "scripting",
    "search"
  ],
  "host_permissions": [
    "https://api.rss2json.com/*",
    "https://api.unsplash.com/*",
    "https://api.github.com/*",
    "https://duckduckgo.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://marketplace.astian.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open-omni": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open command menu"
    }
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_title": "Open Midori command menu"
  },
  "web_accessible_resources": [
    {
      "resources": ["globe.svg", "icons/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
