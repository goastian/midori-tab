{
  "manifest_version": 2,
  "name": "midori-tab",
  "description": "A beautiful, customizable new tab with smart search, workspaces and bookmarks.",
  "author": "Im-Jota",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "identity",
    "tabs",
    "activeTab",
    "bookmarks",
    "history",
    "browsingData",
    "search",
    "https://api.rss2json.com/*",
    "https://api.unsplash.com/*",
    "https://api.github.com/*",
    "https://duckduckgo.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://marketplace.astian.org/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "commands": {
    "open-omni": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open command menu"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "js": [
        "omni-content.js"
      ],
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    "globe.svg",
    "icons/*",
    "assets/*"
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_title": "Open Midori command menu"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "midoritabs@astian.org",
      "strict_min_version": "109.0"
    }
  },
  "version": "1.0.14"
}
