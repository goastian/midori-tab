{
  "manifest_version": 3,
  "name": "midori-tab",
  "description": "A beautiful, customizable new tab with smart search, workspaces and bookmarks.",
  "author": "Im-Jota",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "identity",
    "tabs"
  ],
  "host_permissions": [
    "https://api.rss2json.com/*",
    "https://api.unsplash.com/*",
    "https://api.github.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://marketplace.astian.org/*"
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
